OPENAI_API_KEY=
OPENAI_TRIAGE_MODEL=gpt-5.4-nano
OPENAI_SCAN_MODEL=gpt-5.4-mini
NEXT_PUBLIC_OCR_KOREAN_MODEL_URL=https://paddle-model-ecology.bj.bcebos.com/paddlex/official_inference_model/paddle3.0.0/korean_PP-OCRv5_mobile_rec_onnx_infer.tar
NEXT_PUBLIC_OCR_CONFIDENCE_THRESHOLD=
NEXT_PUBLIC_OCR_MIN_SHORT_SIDE=720
NEXT_PUBLIC_OCR_MIN_BLUR_SCORE=0.0005

# ── 로그인 (next-auth) ──
# AUTH_SECRET: 세션 서명 키. 아래 명령으로 생성해서 채우세요.
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# 소셜 로그인 — 값이 있는 것만 로그인 화면에 버튼이 뜹니다.
# (하나도 없어도 '닉네임 체험 입장'은 항상 동작합니다)
# 각 개발자센터에서 앱 등록 후 Redirect URI를 아래로 맞춰야 합니다.
#   로컬:   http://localhost:3000/api/auth/callback/{kakao|google|naver}
#   프로덕션: https://unmask-sand.vercel.app/api/auth/callback/{kakao|google|naver}
AUTH_KAKAO_ID=
AUTH_KAKAO_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_NAVER_ID=
AUTH_NAVER_SECRET=
